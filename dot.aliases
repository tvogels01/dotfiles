# dotfile target: ~/.aliases

alias la='ls -AG'
alias ll='ls -alF'

if [[ "$CLAUDECODE" = "1" ]]; then
  # Claude Code Bash tool can't answer interactive prompts — skip -i aliases
  true
else
  alias cp='cp -i'
  alias mv='mv -i'
  alias rm='rm -i'
fi

alias h='history'
alias up='cd ..'

alias od='/Applications/Xcode.app/Contents/Developer/usr/bin/opendiff'

# --- Lazy loaders -----------------------------------------------------------

# Delay NVM loading until node tooling is actually used.
#
# The helper name has no leading underscore and the nvm.sh path is inlined (not
# held in a var) on purpose: Claude Code replays a snapshot of this shell that
# strips _-prefixed functions and non-exported vars. The node/npm/nvm stubs
# survive that snapshot, so their helper and its paths must too, or the stubs
# call a missing helper and recurse into themselves.
if [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && ! command -v nvm >/dev/null 2>&1; then
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  dotfiles_load_nvm() {
    unset -f nvm node npm dotfiles_load_nvm >/dev/null 2>&1 || true
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    # shellcheck disable=SC1091
    . "/opt/homebrew/opt/nvm/nvm.sh"
  }
  nvm() {
    dotfiles_load_nvm
    nvm "$@"
  }
  node() {
    dotfiles_load_nvm
    node "$@"
  }
  npm() {
    dotfiles_load_nvm
    npm "$@"
  }
fi

# Delay Conda shell hook until it is actually needed.
#
# Same snapshot constraint as the nvm block above: the `conda` alias survives
# Claude Code's shell snapshot but _-prefixed helpers and the conda path var do
# not, so the helpers use public names and inline the conda path.
if [ -x "/opt/homebrew/Caskroom/miniconda/base/bin/conda" ] && ! typeset -f conda >/dev/null 2>&1; then
  dotfiles_load_conda() {
    unalias conda 2>/dev/null || true
    unset -f dotfiles_load_conda dotfiles_conda_proxy >/dev/null 2>&1 || true
    local shell_name="zsh"
    if [ -n "${BASH_VERSION:-}" ]; then
      shell_name="bash"
    fi
    local __conda_setup
    __conda_setup="$("/opt/homebrew/Caskroom/miniconda/base/bin/conda" "shell.$shell_name" 'hook' 2> /dev/null)" || return
    eval "$__conda_setup"
    unset __conda_setup
  }
  dotfiles_conda_proxy() {
    dotfiles_load_conda
    conda "$@"
  }
  alias conda='dotfiles_conda_proxy'
fi

# --- Helpers ----------------------------------------------------------------

activate() {
  # 1) Node via nvm
  if [ -f .nvmrc ] && command -v nvm >/dev/null 2>&1; then
    nvm use
  fi

  # 2) Conda env matching directory name
  if command -v conda >/dev/null 2>&1; then
    local conda_base cwd_name
    conda_base="$(conda info --base 2>/dev/null || true)"
    cwd_name="$(basename "$PWD")"
    if [ -n "$conda_base" ] && [ -n "$cwd_name" ] && [ -d "$conda_base/envs/$cwd_name" ]; then
      echo "conda activate $cwd_name"
      conda activate "$cwd_name"
    fi
  fi

  # 3) Python virtualenv
  if [ -f .venv/bin/activate ]; then
    echo "source .venv/bin/activate"
    # shellcheck disable=SC1091
    . .venv/bin/activate
  fi
}

export DOTFILES_LOADED_ALIASES=$SHLVL
